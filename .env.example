# ---- App ----
ENVIRONMENT=development
LOG_LEVEL=info
API_V1_PREFIX=/api/v1

# ---- Database (Neon in prod / docker-compose locally) ----
DATABASE_URL=postgresql+asyncpg://lens:lens@localhost:5432/lecturelens
# sync URL for alembic migrations
DATABASE_URL_SYNC=postgresql+psycopg://lens:lens@localhost:5432/lecturelens

# ---- Redis / ARQ queue (Upstash in prod) ----
REDIS_URL=redis://localhost:6379/0

# ---- Auth / JWT (ADR-009) ----
JWT_SECRET=change-me-generate-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ---- CORS (SECURITY.md: explicit allowlist, no wildcard) ----
CORS_ALLOW_ORIGINS=http://localhost:3000

# ---- Object storage (S3-compatible: MinIO local / Supabase / R2) ----
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=lecturelens-audio
STORAGE_REGION=us-east-1

# ---- Upload limits (SPEC §3, SECURITY.md) ----
MAX_UPLOAD_BYTES=52428800        # 50 MB
MAX_AUDIO_DURATION_SECONDS=1800  # 30 min
ALLOWED_AUDIO_MIME=audio/mpeg,audio/wav,audio/x-m4a,audio/ogg

# ---- ML pipeline (ADR-002/003/004) ----
WHISPER_MODEL=base
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_WINDOW_SECONDS=30
CHUNK_OVERLAP_SECONDS=5
FAISS_INDEX_PATH=./data/faiss

# ---- Rate limits (ADR-009 / SECURITY.md) ----
RATE_LIMIT_LOGIN=5/15minutes
RATE_LIMIT_SEARCH=60/minute
MAX_CONCURRENT_JOBS_PER_USER=2
MAX_UPLOADS_PER_HOUR=10

# ---- Phase 2: diarization (pyannote gated model) + YouTube ----
HUGGINGFACE_TOKEN=
YT_DLP_FORMAT=bestaudio

# ---- Frontend (mirror in frontend/.env.example) ----
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
